/* Windows 11 Dark Theme for VisoMaster */

/* Global settings */
QWidget {
    background-color: #1c1c1c; /* Main neutral charcoal background */
    color: #f3f3f3; /* Bright foreground text */
    selection-background-color: #2a4a5e; /* Soft Windows-style blue selection */
    selection-color: #ffffff; /* High-contrast selected text */
}

QLabel {
    color: #f3f3f3; /* Keep labels bright but neutral */
}

QPushButton {
    color: #f3f3f3;
    background-color: #242424; /* Raised surface */
    border: 1px solid #343434; /* Subtle divider border */
    padding: 5px 10px;
    border-radius: 4px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2b2b2b; /* Slight lift on hover */
    border: 1px solid #4cc2ff; /* Windows accent edge */
}

QPushButton:pressed {
    background-color: #4cc2ff; /* Accent fill when active */
    color: #ffffff;
    border: 1px solid #2ea8e6; /* Slightly deeper accent edge */
}

QPushButton:checked {
    background-color: #16384a; /* Soft accent surface */
    border: 1px solid #4cc2ff;
}

QPushButton:disabled {
    background-color: #2b2b2b;
    color: #7a7a7a;
    border: 1px solid #343434;
}

QToolTip {
    color: #f3f3f3;
    background-color: #2a2a2a; /* Elevated surface */
    border: 1px solid #343434;
    padding: 4px;
    border-radius: 3px;
}

/* Base button style for custom cards */
TargetMediaCardButton, TargetFaceCardButton, InputFaceCardButton, EmbeddingCardButton {
    background-color: #242424;
    border-radius: 5px;
    border: 1px solid #343434;
    color: #f3f3f3;
    padding: 10px;
    font-size: 14px;
}

/* Icon inside the button */
TargetMediaCardButton::icon, TargetFaceCardButton::icon, InputFaceCardButton::icon, EmbeddingCardButton::icon {
    margin: 5px;
}

/* Hover state */
TargetMediaCardButton:hover, TargetFaceCardButton:hover, InputFaceCardButton:hover, EmbeddingCardButton:hover {
    background-color: #2b2b2b;
    border: 1px solid #4cc2ff;
}

/* Pressed state */
TargetMediaCardButton:pressed, TargetFaceCardButton:pressed, InputFaceCardButton:pressed, EmbeddingCardButton:pressed {
    background-color: #4cc2ff;
    border: 1px solid #2ea8e6;
    color: #ffffff;
}

/* Checked state */
TargetMediaCardButton:checked, TargetFaceCardButton:checked, InputFaceCardButton:checked, EmbeddingCardButton:checked {
    border: 2px solid #4cc2ff;
    background-color: #16384a;
    color: #ffffff;
}

/* Disabled state */
TargetMediaCardButton:disabled, TargetFaceCardButton:disabled, InputFaceCardButton:disabled, EmbeddingCardButton:disabled {
    background-color: #2b2b2b;
    border: 1px solid #343434;
    color: #7a7a7a;
}

/* Focused state */
TargetMediaCardButton:focus, TargetFaceCardButton:focus, InputFaceCardButton:focus, EmbeddingCardButton:focus {
    outline: none;
    border: 2px solid #4cc2ff;
}


/* QSlider (videoSeekSlider) -------------------------------------- */
#videoSeekSlider::groove:horizontal {
    border-radius: 5px;
    height: 10px;
    margin: 0px;
    background-color: #242424;
}

#videoSeekSlider::groove:horizontal:hover {
    background-color: #2b2b2b;
}

#videoSeekSlider::sub-page:horizontal {
    background-color: #2ea8e6;
    border-radius: 5px;
    height: 10px;
}

#videoSeekSlider::sub-page:horizontal:hover {
    background-color: #4cc2ff;
}

#videoSeekSlider::add-page:horizontal {
    background-color: #343434;
    border-radius: 5px;
    height: 10px;
}

#videoSeekSlider::handle:horizontal {
    background-color: #f3f3f3;
    border: 1px solid #5a5a5a;
    height: 18px;
    width: 8px;
    margin: -4px 0;
    border-radius: 4px;
}

#videoSeekSlider::handle:horizontal:hover {
    background-color: #ffffff;
    border: 1px solid #4cc2ff;
}

#videoSeekSlider::handle:horizontal:pressed {
    background-color: #4cc2ff;
    border: 1px solid #2ea8e6;
}

/* #videoSeekSlider disabled state */
#videoSeekSlider::handle:horizontal:disabled {
    background-color: #5a5a5a;
    border: 1px solid #343434;
}

#videoSeekSlider::groove:horizontal:disabled {
    background-color: #343434;
}

#videoSeekSlider::sub-page:horizontal:disabled {
    background-color: #7a7a7a;
}


/* ToggleButton (assuming custom class) */
ToggleButton {
    border: 1px solid #343434;
    border-radius: 6px;
    background-color: #c42b1c; /* Windows-style destructive red */
    color: #ffffff;
    text-align: center;
    padding: 4px;
    font-weight: bold;
}
ToggleButton:hover {
    background-color: #d13438;
    border: 1px solid #e38b8f;
}
ToggleButton:pressed {
    background-color: #6bbe6b; /* Existing success semantics */
}
ToggleButton:checked {
    background-color: #6bbe6b;
    border: 1px solid #9bdb9b;
}
ToggleButton:default {
    border-color: #343434;
}


/* ParameterSlider / ParameterDecimalSlider - Thin Groove and Handle */
/* -------------------------------------- */
ParameterSlider::groove:horizontal, ParameterDecimalSlider::groove:horizontal {
    border-radius: 3px;
    height: 6px;
    margin: 0px;
    background-color: #242424;
}

ParameterSlider::sub-page:horizontal, ParameterDecimalSlider::sub-page:horizontal {
    background-color: #4cc2ff;
    border-radius: 3px;
    height: 6px;
}

ParameterSlider::add-page:horizontal, ParameterDecimalSlider::add-page:horizontal {
    background-color: #343434;
    border-radius: 3px;
    height: 6px;
}

ParameterSlider::handle:horizontal, ParameterDecimalSlider::handle:horizontal {
    background-color: #f3f3f3;
    border: 1px solid #5a5a5a;
    height: 16px;
    width: 6px;
    margin: -5px 0;
    border-radius: 3px;
}

ParameterSlider::handle:horizontal:hover, ParameterDecimalSlider::handle:horizontal:hover {
    background-color: #ffffff;
    border: 1px solid #4cc2ff;
}

/* Disabled state */
ParameterSlider::handle:horizontal:disabled, ParameterDecimalSlider::handle:horizontal:disabled {
    background-color: #5a5a5a;
    border: 1px solid #343434;
}

ParameterSlider::groove:horizontal:disabled, ParameterDecimalSlider::groove:horizontal:disabled {
    background-color: #343434;
}

ParameterSlider::sub-page:horizontal:disabled, ParameterDecimalSlider::sub-page:horizontal:disabled {
    background-color: #7a7a7a;
}

/* Add styles for other common widgets if needed */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #1f1f1f; /* Input surface */
    color: #f3f3f3;
    border: 1px solid #343434;
    border-radius: 3px;
    padding: 4px;
}

QComboBox {
    border: 1px solid #343434;
    border-radius: 3px;
    padding: 1px 18px 1px 3px;
    min-width: 6em;
    background-color: #242424;
    color: #f3f3f3;
}

QComboBox:editable {
    background: #1f1f1f;
}

QComboBox:!editable, QComboBox::drop-down:editable {
     background: #242424;
}

/* QComboBox gets the "on" state when the popup is open */
QComboBox:!editable:on, QComboBox::drop-down:editable:on {
    background: #2b2b2b;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 15px;
    border-left-width: 1px;
    border-left-color: #343434;
    border-left-style: solid;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
}

QComboBox QAbstractItemView { /* Style for the dropdown list */
    border: 1px solid #343434;
    background-color: #242424;
    selection-background-color: #2a4a5e;
    selection-color: #ffffff;
    color: #f3f3f3;
}

QMenuBar {
    background-color: #242424;
    color: #f3f3f3;
}

QMenuBar::item {
    background: transparent;
    padding: 4px 8px;
}

QMenuBar::item:selected { /* when selected using mouse or keyboard */
    background: #2a4a5e;
    color: #ffffff;
}

QMenuBar::item:pressed {
    background: #16384a;
}

QMenu {
    background-color: #2a2a2a;
    border: 1px solid #343434;
    color: #f3f3f3;
}

QMenu::item {
    padding: 4px 20px 4px 20px;
}

QMenu::item:selected {
    background-color: #2a4a5e;
    color: #ffffff;
}

QMenu::separator {
    height: 1px;
    background: #343434;
    margin-left: 10px;
    margin-right: 5px;
}

QScrollBar:vertical {
    border: 1px solid #343434;
    background: #1e1e1e;
    width: 12px;
    margin: 0px 0px 0px 0px;
}
QScrollBar::handle:vertical {
    background: #5a5a5a;
    min-height: 20px;
    border-radius: 6px;
}
QScrollBar::handle:vertical:hover {
    background: #787878;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    border: 1px solid #343434;
    background: #1e1e1e;
    height: 12px;
    margin: 0px 0px 0px 0px;
}
QScrollBar::handle:horizontal {
    background: #5a5a5a;
    min-width: 20px;
    border-radius: 6px;
}
QScrollBar::handle:horizontal:hover {
    background: #787878;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
    background: none;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

QTabWidget::pane { /* The tab widget frame */
    border-top: 1px solid #343434;
}

QTabWidget::tab-bar {
    left: 5px; /* move to the right by 5px */
}

/* Style the tab using the tab sub-control. Note that it reads QTabBar _not_ QTabWidget */
QTabBar::tab {
    background: #242424;
    border: 1px solid #343434;
    border-bottom-color: #343434;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    min-width: 8ex;
    padding: 4px 8px;
    color: #f3f3f3;
}

QTabBar::tab:selected, QTabBar::tab:hover {
    background: #2b2b2b;
    border-color: #454545;
    border-bottom-color: #2b2b2b;
}

QTabBar::tab:selected {
    background: #2a4a5e;
    color: #ffffff;
    border-color: #4cc2ff;
    border-bottom-color: #2a4a5e;
}

QTabBar::tab:!selected {
    margin-top: 2px; /* make non-selected tabs look smaller */
}

/* Add more widget styles as needed */

/* Frame borders */
QFrame, QListWidget {
	background-color: transparent;
}
